# ===========================================
# Vibe Any - Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values
# Most variables are OPTIONAL - the app can run in "static mode" with zero configuration

# ===========================================
# Core Configuration (Optional)
# ===========================================
# Without these, the app runs in "static mode" (Landing, Docs, Blog only)

# Application URL (default: http://localhost:3377)
VITE_APP_URL=http://localhost:3377

# Database connection string (PostgreSQL)
# Without this, user authentication and all user-related features are disabled
DATABASE_URL=

# ===========================================
# Authentication (Requires DATABASE_URL)
# ===========================================

# Secret key for authentication (required if using auth)
BETTER_AUTH_SECRET=

# OAuth Providers (optional)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Cloudflare Turnstile Captcha (optional)
VITE_TURNSTILE_CAPTCHA_ENABLED=false
VITE_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ===========================================
# Email Service (Optional)
# ===========================================
# Required for email verification and magic links

# Email provider: "resend" or "custom"
EMAIL_PROVIDER=
EMAIL_FROM=

# Email verification (default: false)
# Set to true to require email verification on sign up
EMAIL_VERIFICATION_ENABLED=false

# For Resend provider
RESEND_API_KEY=

# For Custom SMTP provider
EMAIL_HOST=
EMAIL_USER=
EMAIL_PASSWORD=

# ===========================================
# Storage Service (Optional)
# ===========================================
# S3-compatible storage for file uploads

STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_REGION=auto
STORAGE_BUCKET_NAME=
STORAGE_ENDPOINT=
STORAGE_PUBLIC_URL=

# ===========================================
# Payment (Optional, configured in admin panel)
# ===========================================
# Payment configuration is stored in database and managed via admin panel
# These are only needed if you want to override database settings

# Stripe Price IDs (for pricing display)
VITE_STRIPE_PRO_MONTHLY_PRICE_ID=
VITE_STRIPE_PRO_YEARLY_PRICE_ID=
VITE_STRIPE_LIFETIME_PRICE_ID=

# Crypto payment feature flag
# Set VITE_CRYPTO_PAYMENT_ENABLED=true to show crypto as a payment option.
VITE_CRYPTO_PAYMENT_ENABLED=false
# Optional comma-separated allowlist, e.g. "usdc_sol", "usdc_sol,sol",
# or "usdc_sol,usdt_trc20,bnb_bsc,usdt_bep20".
# The listed order is preserved in the pricing dropdown, so put currencies in the desired display order.
# Leave empty to hide all crypto currencies. Remove this key to allow all supported currencies.
VITE_CRYPTO_ENABLED_CURRENCIES=

# Solana Pay
SOLANAPAY_WALLET_ADDRESS=
SOLANAPAY_NETWORK=devnet
SOLANAPAY_RPC_URL=

# BNB Smart Chain direct checkout (used by bnb_bsc / usdt_bep20)
# EVM_DIRECT_MERCHANT_WALLET must be a valid 0x-prefixed wallet address.
EVM_DIRECT_MERCHANT_WALLET=
# Primary BSC RPC endpoint. Required for EVM direct checkout.
BSC_RPC_URL=
# Optional fallback BSC RPC endpoint.
BSC_RPC_FALLBACK_URL=
# Supported values: mainnet, testnet
BSC_NETWORK=mainnet

# Live crypto quotes for volatile assets (BTC / ETH / SOL / TRX / BNB)
# Provider: "binance" or "mock"
CRYPTO_QUOTE_PROVIDER=binance
# Binance Spot API base URL
CRYPTO_QUOTE_API_URL=https://api.binance.com
# Quote request timeout in milliseconds
CRYPTO_QUOTE_TIMEOUT_MS=5000
# Locked quote lifetime in seconds
CRYPTO_QUOTE_EXPIRES_IN_SECONDS=900

# ===========================================
# Analytics (Optional)
# ===========================================

# Google Analytics Measurement ID (e.g. G-XXXXXXXXXX)
VITE_GA_MEASUREMENT_ID=

# ===========================================
# Other Settings
# ===========================================

# Currency display (default: USD)
VITE_CURRENCY=USD

# Environment (production/development)
VITE_ENV=development
